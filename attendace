<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Feeding India | School Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #fdfdfd; user-select: none; }
        
        /* Holiday Styles - Tactile Gradients */
        .day-nat { background: linear-gradient(135deg, #f97316, #ea580c) !important; color: white !important; border: none !important; }
        .day-wkd { background: linear-gradient(135deg, #3b82f6, #2563eb) !important; color: white !important; border: none !important; }
        .day-sch { background: linear-gradient(135deg, #facc15, #eab308) !important; color: black !important; border: none !important; }
        .day-emg { background: linear-gradient(135deg, #ef4444, #dc2626) !important; color: white !important; border: none !important; }
        .day-none { background: white; border: 2px solid #f1f5f9; color: #64748b; }

        .wizard-step { display: none; }
        .wizard-step.active { display: block; animation: slideIn 0.3s ease-out; }
        @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

        .wkd-chip { border: 2px solid #e2e8f0; transition: 0.2s; cursor: pointer; border-radius: 16px; padding: 16px; font-weight: 700; text-align: center; }
        .wkd-chip.selected { border-color: #3b82f6; background: #eff6ff; color: #1e40af; transform: scale(1.05); }

        .calendar-day { aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; border-radius: 14px; font-weight: 800; cursor: pointer; transition: 0.1s; }
        .range-selecting { border: 4px dashed #0f172a !important; animation: pulse 1s infinite; }
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.6; } 100% { opacity: 1; } }

        /* Small legend dots */
        .dot { width: 12px; height: 12px; border-radius: 4px; display: inline-block; margin-right: 6px; }
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden">

    <header class="p-4 bg-white border-b flex justify-between items-center z-50">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center text-white font-black text-xs">FI</div>
            <h1 class="font-black text-slate-800 tracking-tight">Feeding India</h1>
        </div>
        <select id="langSelect" onchange="changeLang(this.value)" class="bg-slate-100 rounded-xl px-3 py-2 text-xs font-bold border-none outline-none">
            <option value="en">English</option>
            <option value="hi">हिन्दी</option>
            <option value="mr">मराठी</option>
        </select>
    </header>

    <main class="flex-grow relative overflow-y-auto">
        
        <section id="step1" class="wizard-step active p-6 max-w-md mx-auto">
            <div class="mb-8">
                <p id="s1-tag" class="text-[10px] font-black text-blue-600 uppercase tracking-widest mb-1">Yearly Setup</p>
                <h2 id="s1-title" class="text-2xl font-black text-slate-900">Weekly Holidays?</h2>
                <p id="s1-sub" class="text-slate-500 text-sm mt-2">Tap all the days your school is closed every week.</p>
            </div>
            <div class="grid grid-cols-2 gap-3" id="wkd-container"></div>
            <button onclick="goToStep(2)" class="w-full mt-10 bg-slate-900 text-white py-5 rounded-2xl font-black uppercase tracking-wider shadow-lg active:scale-95 transition-all" id="btn-next-1">Continue</button>
        </section>

        <section id="step2" class="wizard-step p-6 max-w-md mx-auto">
            <div class="mb-8 text-center">
                <h2 id="s2-title" class="text-2xl font-black text-slate-900">National Holidays</h2>
                <p id="s2-sub" class="text-slate-500 text-sm mt-1">Confirmed for 2026</p>
            </div>
            <div class="space-y-3 mb-8" id="nat-list"></div>
            <button onclick="goToStep(3)" class="w-full bg-slate-900 text-white py-5 rounded-2xl font-black uppercase" id="btn-next-2">Looks Good</button>
        </section>

        <section id="step3" class="wizard-step h-full">
            <div class="flex border-b bg-white sticky top-0 z-10">
                <button onclick="showTab('scan')" id="tab-scan" class="flex-1 py-4 text-xs font-black border-b-4 border-slate-900">ATTENDANCE</button>
                <button onclick="showTab('cal')" id="tab-cal" class="flex-1 py-4 text-xs font-black text-slate-400">CALENDAR</button>
            </div>

            <div id="content-scan" class="p-6">
                <div class="aspect-square bg-slate-900 rounded-[40px] relative overflow-hidden flex flex-col items-center justify-center shadow-2xl">
                    <div class="absolute w-full h-1 bg-green-500 top-0 animate-[bounce_4s_infinite] shadow-[0_0_20px_#22c55e]"></div>
                    <div class="w-32 h-32 border-2 border-white/5 rounded-full animate-pulse"></div>
                    <p class="text-white/20 font-black text-[10px] tracking-widest uppercase mt-4">Scanner Online</p>
                </div>

                <div class="mt-6 flex gap-3">
                    <div class="flex-1 bg-slate-100 p-5 rounded-3xl border border-slate-200">
                        <p class="text-2xl font-black text-slate-800">412 / 450</p>
                        <p id="l-present" class="text-[10px] font-bold text-slate-400 uppercase">Present</p>
                    </div>
                    <button onclick="markEmergencyToday()" class="flex-1 bg-red-50 text-red-600 p-5 rounded-3xl border-2 border-red-100 flex flex-col items-center justify-center active:bg-red-600 active:text-white transition-colors">
                        <span class="text-xl">🚨</span>
                        <span id="btn-emergency" class="text-[9px] font-black uppercase mt-1">Closed Today</span>
                    </button>
                </div>
            </div>

            <div id="content-cal" class="hidden p-6 pb-32">
                
                <div class="mb-6 p-4 bg-slate-50 rounded-2xl grid grid-cols-2 gap-y-2 gap-x-4">
                    <div class="flex items-center text-[10px] font-bold text-slate-600"><span class="dot day-nat"></span><span id="leg-nat">National</span></div>
                    <div class="flex items-center text-[10px] font-bold text-slate-600"><span class="dot day-wkd"></span><span id="leg-wkd">Weekend</span></div>
                    <div class="flex items-center text-[10px] font-bold text-slate-600"><span class="dot day-sch"></span><span id="leg-sch">School Holiday</span></div>
                    <div class="flex items-center text-[10px] font-bold text-slate-600"><span class="dot day-emg"></span><span id="leg-emg">Emergency</span></div>
                </div>

                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-xl font-black text-slate-800">March 2026</h3>
                    <button id="rangeBtn" onclick="toggleRangeMode()" class="px-4 py-2 rounded-xl bg-white text-[10px] font-black border-2 border-slate-200 shadow-sm transition-all">
                        RANGE: <span id="rangeStatus">OFF</span>
                    </button>
                </div>

                <div id="calendarGrid" class="grid grid-cols-7 gap-2"></div>

                <div class="mt-8 bg-slate-900 rounded-[32px] p-7 text-white shadow-2xl relative overflow-hidden">
                    <div class="relative z-10 flex justify-between items-end">
                        <div>
                            <h4 id="mealTotal" class="text-4xl font-black text-orange-400 leading-none">0</h4>
                            <p id="l-meals" class="text-[10px] font-bold text-white/40 uppercase mt-2">Expected Meals</p>
                        </div>
                        <button onclick="alert('Sent!')" class="bg-white text-slate-900 px-6 py-3 rounded-xl font-black text-[10px] uppercase shadow-lg">Sync Kitchen</button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        const i18n = {
            en: {
                s1: "Recurring Holidays", s1sub: "Select weekly closed days",
                days: ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
                next: "Continue", nat_list: ["Holi - Mar 14", "Eid - Mar 31"],
                present: "Present", emergency: "Closed Today", meals: "Expected Meals",
                leg_nat: "National Holiday", leg_wkd: "Weekly Off", leg_sch: "School Holiday", leg_emg: "Emergency"
            },
            hi: {
                s1: "साप्ताहिक सुट्टियां", s1sub: "साप्ताहिक छुट्टियों का चयन करें",
                days: ["रविवार", "सोमवार", "मंगलवार", "बुधवार", "गुरुवार", "शुक्रवार", "शनिवार"],
                next: "आगे बढ़ें", nat_list: ["होली - 14 मार्च", "ईद - 31 मार्च"],
                present: "उपस्थित", emergency: "आज छुट्टी है", meals: "भोजन आवश्यकता",
                leg_nat: "राष्ट्रीय छुट्टी", leg_wkd: "साप्ताहिक छुट्टी", leg_sch: "स्कूल छुट्टी", leg_emg: "आपातकालीन"
            },
            mr: {
                s1: "साप्ताहिक सुट्ट्या", s1sub: "साप्ताहिक सुट्ट्या निवडा",
                days: ["रविवार", "सोमवार", "मंगळवार", "बुधवार", "गुरुवार", "शुक्रवार", "शनिवार"],
                next: "पुढची पायरी", nat_list: ["होळी - १४ मार्च", "ईद - ३१ मार्च"],
                present: "हजर", emergency: "आज सुट्टी आहे", meals: "जेवण गरज",
                leg_nat: "राष्ट्रीय सुट्टी", leg_wkd: "साप्ताहिक सुट्टी", leg_sch: "शाळा सुट्टी", leg_emg: "आणीबाणी"
            }
        };

        let state = {
            lang: 'en',
            weekends: [0], 
            calendar: Array(32).fill('none'),
            rangeMode: false,
            rangeStart: null
        };

        function changeLang(lang) {
            state.lang = lang;
            const t = i18n[lang];
            document.getElementById('s1-title').innerText = t.s1;
            document.getElementById('s1-sub').innerText = t.s1sub;
            document.getElementById('btn-next-1').innerText = t.next;
            document.getElementById('l-present').innerText = t.present;
            document.getElementById('btn-emergency').innerText = t.emergency;
            document.getElementById('l-meals').innerText = t.meals;
            
            // Legend
            document.getElementById('leg-nat').innerText = t.leg_nat;
            document.getElementById('leg-wkd').innerText = t.leg_wkd;
            document.getElementById('leg-sch').innerText = t.leg_sch;
            document.getElementById('leg-emg').innerText = t.leg_emg;
            
            const container = document.getElementById('wkd-container');
            container.innerHTML = '';
            t.days.forEach((d, i) => {
                const isSelected = state.weekends.includes(i);
                container.innerHTML += `<div onclick="toggleWkd(${i})" class="wkd-chip ${isSelected?'selected':''}">${d}</div>`;
            });

            const list = document.getElementById('nat-list');
            list.innerHTML = '';
            t.nat_list.forEach(h => {
                list.innerHTML += `<div class="bg-white border p-4 rounded-xl flex justify-between font-bold text-sm"><span>${h}</span><span class="text-orange-500">✔</span></div>`;
            });
        }

        function toggleWkd(dayIndex) {
            if(state.weekends.includes(dayIndex)) {
                state.weekends = state.weekends.filter(d => d !== dayIndex);
            } else {
                state.weekends.push(dayIndex);
            }
            changeLang(state.lang);
        }

        function goToStep(s) {
            document.querySelectorAll('.wizard-step').forEach(step => step.classList.remove('active'));
            document.getElementById('step' + s).classList.add('active');
            if(s === 3) applyInitialState();
        }

        function applyInitialState() {
            for(let i=1; i<=31; i++) {
                const dayOfWeek = (i - 1) % 7; 
                if(state.weekends.includes(dayOfWeek)) state.calendar[i] = 'wkd';
            }
            state.calendar[14] = 'nat';
            state.calendar[31] = 'nat';
            renderCalendar();
        }

        function markEmergencyToday() {
            state.calendar[3] = 'emg'; // Today is Mar 3, 2026
            alert("EMERGENCY: Kitchen notified to STOP production today.");
            renderCalendar();
        }

        function toggleRangeMode() {
            state.rangeMode = !state.rangeMode;
            state.rangeStart = null;
            document.getElementById('rangeStatus').innerText = state.rangeMode ? "ON" : "OFF";
            document.getElementById('rangeBtn').classList.toggle('bg-slate-900', state.rangeMode);
            document.getElementById('rangeBtn').classList.toggle('text-white', state.rangeMode);
            renderCalendar();
        }

        function handleDateClick(day) {
            if(!state.rangeMode) {
                state.calendar[day] = state.calendar[day] === 'sch' ? 'none' : 'sch';
            } else {
                if(state.rangeStart === null) {
                    state.rangeStart = day;
                } else {
                    const start = Math.min(state.rangeStart, day);
                    const end = Math.max(state.rangeStart, day);
                    for(let i=start; i<=end; i++) state.calendar[i] = 'sch';
                    state.rangeStart = null;
                }
            }
            renderCalendar();
        }

        function renderCalendar() {
            const grid = document.getElementById('calendarGrid');
            grid.innerHTML = '';
            let holidays = 0;
            for(let i=1; i<=31; i++) {
                const type = state.calendar[i];
                const day = document.createElement('div');
                day.className = `calendar-day day-${type}`;
                if(state.rangeStart === i) day.classList.add('range-selecting');
                day.innerText = i;
                day.onclick = () => handleDateClick(i);
                grid.appendChild(day);
                if(type !== 'none') holidays++;
            }
            document.getElementById('mealTotal').innerText = ((31-holidays)*450).toLocaleString();
        }

        function showTab(t) {
            document.getElementById('content-scan').classList.toggle('hidden', t !== 'scan');
            document.getElementById('content-cal').classList.toggle('hidden', t !== 'cal');
            document.getElementById('tab-scan').classList.toggle('border-slate-900', t === 'scan');
            document.getElementById('tab-cal').classList.toggle('border-slate-900', t === 'cal');
            document.getElementById('tab-scan').classList.toggle('text-slate-400', t !== 'scan');
            document.getElementById('tab-cal').classList.toggle('text-slate-400', t !== 'cal');
        }

        changeLang('en');
    </script>
</body>
</html>
